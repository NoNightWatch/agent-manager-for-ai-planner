# ─────────────────────────────────────────────────────────────────────────────
# AI Agent Orchestrator — Environment Variables
#
# Copy this file to .env and fill in the values you need.
# You only need ONE provider key to get real model responses.
# Leave everything blank to run in mock mode (great for local testing).
#
# Quick start (no API key required):
#   npx tsx src/cli.ts "Write a bubble sort in Python"
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM Provider API Keys ─────────────────────────────────────────────────────

# Anthropic (Claude) — set this to use claude-haiku / claude-sonnet / claude-opus
ANTHROPIC_API_KEY=

# OpenAI — set this to use gpt-4o-mini / gpt-4o / o1-preview
OPENAI_API_KEY=

# Custom LLM Gateway — if you route traffic through your own gateway proxy
GATEWAY_URL=
GATEWAY_API_KEY=
GATEWAY_STEP_PATH=/v1/llm/step
GATEWAY_TIMEOUT_MS=30000


# ── Provider Selection ────────────────────────────────────────────────────────

# Which provider to use by default. Options: mock | anthropic | openai | gateway
# 'mock' works without any API keys and is great for testing the orchestration flow.
DEFAULT_PROVIDER_ID=mock

# Legacy alias (DEFAULT_PROVIDER_ID takes priority)
# LLM_PROVIDER=mock


# ── Outbound Network Policy ───────────────────────────────────────────────────

# Comma-separated list of allowed outbound hostnames.
# 'openrouter.ai' is included by default so live model pricing is fetched
# automatically without any extra configuration.
OUTBOUND_ALLOWLIST=openrouter.ai

# Add your LLM provider hosts here when you enable them, for example:
#   OUTBOUND_ALLOWLIST=openrouter.ai,api.openai.com,api.anthropic.com

# Set to '1' to allow ALL outbound hosts (NOT recommended in production).
OUTBOUND_ALLOW_ALL=0


# ── OpenRouter Model Pricing ──────────────────────────────────────────────────

# Override model tier → real model ID mappings per provider.
# Useful when you want to pin to a specific model version.
# ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_STANDARD=claude-sonnet-4-6
# ANTHROPIC_MODEL_PREMIUM=claude-opus-4-6

# OPENAI_MODEL_CHEAP=gpt-4o-mini
# OPENAI_MODEL_STANDARD=gpt-4o
# OPENAI_MODEL_PREMIUM=o1-preview


# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Max wall-clock time for a synchronous /v1/run/sync request (ms).
RUN_SYNC_TIMEOUT_MS=30000


# ── Authentication ────────────────────────────────────────────────────────────

# Set REQUIRE_RUN_TOKEN=1 and provide tokens to gate access.
REQUIRE_RUN_TOKEN=0
# Comma-separated list of accepted opaque tokens.
RUN_TOKENS=

# JWT (HS256) — alternative to opaque tokens.
# JWT payload must contain "sub" (used as token owner).
JWT_SECRET=
JWT_AUDIENCE=

# Allow unauthenticated GET requests to /v1/run/* (read-only endpoints).
ALLOW_ANONYMOUS_READ=0


# ── Tool Settings ─────────────────────────────────────────────────────────────

# Set ENABLE_TOOL_REGISTRATION=1 to allow clients to register custom tools via
# POST /v1/tools. Leave off in production unless you trust all callers.
ENABLE_TOOL_REGISTRATION=0

# Comma-separated tool names clients are allowed to register (empty = all).
TOOL_ALLOWLIST=

# Allow tool callbacks to reach http://localhost (for local dev tool servers).
TOOL_CALLBACK_ALLOW_LOCAL_TEST=0


# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Max concurrent runs per token owner.
TOKENOWNER_MAX_RUNNING=8
# Max runs started per minute per token owner.
TOKENOWNER_MAX_PER_MINUTE=60


# ── Persistence ───────────────────────────────────────────────────────────────

# Set PERSIST_RUNS=1 to write run state to disk (./runs/) so it survives restarts.
PERSIST_RUNS=0


# ── Telemetry / Observability ─────────────────────────────────────────────────

# Redact potentially sensitive text in event payloads before logging.
REDACT_TELEMETRY=0
# REDACT_TELEMETRY_MODE=none   # none | hash | truncate
